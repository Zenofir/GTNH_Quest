      "id": "8db7ebbb-0748-419a-82e9-833e65aa890c",
      "name": "Loop Over Items"
    },
    {
      "parameters": {
        "jsCode": "const sd = $getWorkflowStaticData('global');\n\nconst SYSTEM = `Tu es un traducteur expert pour le jeu Minecraft. Traduis en français les textes du dictionnaire JSON fourni.\nChaque clé est un identifiant de quête, la valeur est le texte à traduire. Retourne UNIQUEMENT un dictionnaire JSON avec les mêmes clés et les valeurs traduites en français.\n\nRègles strictes :\n- Conserve les balises § suivies d'un caractère (§0-9, §a-f, §l, §r, §o, §n, §m, §k)\n- Conserve les balises HTML : <br/>, <br>, <a href=\"...\">\n- Conserve [url]...[/url], [warn]...[/warn], [note]...[/note]\n- Ne traduis pas les noms d'items Minecraft, mods, biomes ou dimensions\n- Réponds UNIQUEMENT avec le dictionnaire JSON traduit, sans markdown, sans commentaire`;\n\nconst batch = {};\nfor (const item of $input.all()) {\n  const j = item.json;\n  if (j.quest_id !== undefined) {\n    // Format individuel : {quest_id, data}\n    batch[j.quest_id] = j.data;\n  } else {\n    // Format clés numériques : {\"0\": {quest_id, data}, \"1\": {...}, ...}\n    for (const key of Object.keys(j)) {\n      const q = j[key];\n      if (q && typeof q === 'object' && q.quest_id !== undefined) {\n        batch[q.quest_id] = q.data;\n      }\n    }\n  }\n}\n\nreturn [{ json: { systemPrompt: SYSTEM, prompt: JSON.stringify(batch) } }];\n"
      },
      "id": "e4dfb2f2-7f7a-4f32-a03e-a5b6ff5cba0b",
      "name": "Split into chunks",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        400,
        1328
      ]
    },
    {
      "parameters": {
        "jsCode": "const sd = $getWorkflowStaticData('global');\nif (!sd.translations) sd.translations = {};\n\n// Format Gemini: [{ candidates: [{ content: { parts: [{ text: '{\"id\":\"trad\",...}' }] } }] }]\nconst text = $input.first().json?.candidates?.[0]?.content?.parts?.[0]?.text ?? '';\n\nconst cleaned = text\n  .replace(/^```json\\s*/m, '')\n  .replace(/^```\\s*/m, '')\n  .replace(/\\s*```$/m, '')\n  .trim();\n\ntry {\n  const parsed = JSON.parse(cleaned);\n  if (typeof parsed === 'object' && !Array.isArray(parsed)) {\n    Object.assign(sd.translations, parsed);\n    console.log(`Accumulé : ${Object.keys(parsed).length} — total : ${Object.keys(sd.translations).length}`);\n  } else {\n    console.error('Réponse non-objet:', typeof parsed, cleaned.substring(0, 200));\n  }\n} catch(e) {\n  console.error('Erreur parsing:', e.message, cleaned.substring(0, 300));\n}\n\nreturn $input.all();\n"
      },
      "id": "776145a9-f089-45ca-8e33-9692f64574ff",
      "name": "Accumulate",
