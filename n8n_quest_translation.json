        "jsCode": "const sd = $getWorkflowStaticData('global');\nconst all = sd.translations ?? {};\nsd.translations = {};\n\nconsole.log(`Total traduit : ${Object.keys(all).length} quêtes`);\nreturn [{ json: all }];"
      },
